---
const currentPath = Astro.url.pathname;
---

<div class="flex justify-between items-center pb-14 w-full">
  <div class="flex sm:gap-6 gap-4 text-slate-800">
    <a
      href="/"
      class={`text-xl flex items-center justify-center ${
        currentPath === "/" ? " text-blue-500 font-bold" : ""
      }`}
    >
      Home
    </a>
    <a
      href="/work/"
      class={`text-xl flex items-center justify-center ${
        currentPath === "/work/" ? "text-blue-500 font-bold" : ""
      }`}
    >
      Work
    </a>
  </div>

  <img
    src="/images/profile.png"
    alt="Face shot"
    class="w-20 h-20 rounded-full"
  />
</div>
