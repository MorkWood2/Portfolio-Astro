---
const currentPath = Astro.url.pathname;
---

<div class="flex justify-between items-center pb-14 w-full">
  <div
    class="flex sm:gap-6 gap-4 text-slate-800 dark:text-slate-200 dark:text-slate-200"
  >
    <a
      href="/"
      class={`text-xl flex items-center justify-center ${currentPath === "/" ? " text-blue-500 dark:text-blue-400 font-bold" : ""}`}
    >
      Home
    </a>
    <a
      href="/work/"
      class={`text-xl flex items-center justify-center ${currentPath === "/work/" ? "text-blue-500 dark:text-blue-400 font-bold" : ""}`}
    >
      Work
    </a>
  </div>

  <div class="flex items-center gap-4">
    <button
      id="theme-toggle"
      type="button"
      title="Toggle theme"
      aria-label="Toggle theme"
      class="theme-toggle text-orange-400 dark:text-yellow-200 text-2xl p-1 hover:opacity-70 transition-opacity"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        width="1em"
        height="1em"
        fill="currentColor"
        class="theme-toggle__around"
        viewBox="0 0 32 32"
      >
        <clipPath id="theme-toggle__around__cutout">
          <path d="M0 0h42v30a1 1 0 00-16 13H0Z"></path>
        </clipPath>
        <g clip-path="url(#theme-toggle__around__cutout)">
          <circle cx="16" cy="16" r="8.4"></circle>
          <g>
            <circle cx="16" cy="3.3" r="2.3"></circle>
            <circle cx="27" cy="9.7" r="2.3"></circle>
            <circle cx="27" cy="22.3" r="2.3"></circle>
            <circle cx="16" cy="28.7" r="2.3"></circle>
            <circle cx="5" cy="22.3" r="2.3"></circle>
            <circle cx="5" cy="9.7" r="2.3"></circle>
          </g>
        </g>
      </svg>
    </button>
    <img
      src="/images/profile.jpeg"
      alt="Face shot"
      class="w-20 h-20 rounded-full"
    />
  </div>
</div>

<script>
  const toggle = document.getElementById("theme-toggle");

  if (document.documentElement.classList.contains("dark")) {
    toggle?.classList.add("theme-toggle--toggled");
  }

  // Mark ready — button becomes visible now that state is correct
  document.documentElement.classList.add("theme-toggle-ready");

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      toggle?.classList.add("theme-toggle--allow-transition");
    });
  });

  toggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    toggle.classList.toggle("theme-toggle--toggled", isDark);
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
</script>
