---
import Topbar from "../components/Topbar.astro";
import "../styles/global.css";
const { pageTitle } = Astro.props;
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/theme-toggles@4.10.1/css/around.min.css"
    />

    <script is:inline>
      if (localStorage.getItem("theme") !== "light") {
        document.documentElement.classList.add("dark");
      }
    </script>

    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="48e9b33c-7230-4738-9960-322c861997ed"></script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="bg-zinc-50 dark:bg-zinc-950 antialiased">
      <div
        class="max-w-5xl mx-auto py-12 px-4 sm:px-12 md:px-16 bg-white dark:bg-zinc-900 min-h-screen flex flex-col items-stretch"
      >
        <Topbar />
        <slot />
        <div class="w-full border-t border-zinc-200 dark:border-zinc-800 mt-14">
          <div class="pt-4 text-sm text-zinc-500 dark:text-zinc-400">
            {year} © Mark Wild
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
